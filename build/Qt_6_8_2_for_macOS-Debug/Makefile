FitBuddy.app/Contents/PkgInfo: 
	@test -d FitBuddy.app/Contents || mkdir -p FitBuddy.app/Contents
	@$(DEL_FILE) FitBuddy.app/Contents/PkgInfo
	@echo "APPL????" > FitBuddy.app/Contents/PkgInfo
FitBuddy.app/Contents/Info.plist: 
	@test -d FitBuddy.app/Contents || mkdir -p FitBuddy.app/Contents
	@$(DEL_FILE) FitBuddy.app/Contents/Info.plist
	@plutil -convert xml1 -o - ../../../../Qt/6.8.2/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.shaan.FitBuddy,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.shaan.FitBuddy,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},12,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,FitBuddy,g" -e "s,@LIBRARY@,FitBuddy,g" -e "s,\$${EXECUTABLE_NAME},FitBuddy,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >FitBuddy.app/Contents/Info.plist

all: Makefile \
		FitBuddy.app/Contents/PkgInfo \
