####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/FitBuddy/bin || mkdir -p $(INSTALL_ROOT)/opt/FitBuddy/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/FitBuddy/bin/FitBuddy.app
	
	$(QINSTALL) FitBuddy.app $(INSTALL_ROOT)/opt/FitBuddy/bin/FitBuddy.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/FitBuddy/bin/FitBuddy.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/FitBuddy/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

